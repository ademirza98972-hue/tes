{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/studio", "destination": "/index.html" },
    { "source": "/", "destination": "/landing.html" },
    { "source": "/(.*)", "destination": "/landing.html" }
  ]
}
