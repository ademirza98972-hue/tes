{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/login", "dest": "/api/login.js" },
    { "src": "/api/callback", "dest": "/api/callback.js" },
    { "src": "/api/me", "dest": "/api/me.js" },
    { "src": "/api/bypass", "dest": "/api/bypass.js" },
    { "src": "/api/logout", "dest": "/api/logout.js" },
    { "src": "/api/admin", "dest": "/api/admin.js" },
    { "src": "/api/users", "dest": "/api/users.js" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
